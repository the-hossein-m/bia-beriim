{
  "version": 2,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/", "dest": "/setup.html" },
    { "src": "/setup", "dest": "/setup.html" },
    { "src": "/invite", "dest": "/bia-beriim.html" }
  ]
}
